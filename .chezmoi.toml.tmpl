{{/* chezmoi config — generated by `chezmoi init`.
     Prompts for git identity and a few opt-in toggles, then auto-detects
     the OS / distro / WSL environment so templates can branch on it. */}}

{{- $gitName := promptStringOnce . "gitName" "Full name for git commits" "" -}}
{{- $gitEmail := promptStringOnce . "gitEmail" "Email for git commits" "" -}}
{{- $enableGcloudAdc := promptBoolOnce . "enableGcloudAdc" "Show gcloud ADC account in starship prompt? (leaks service-account email in screenshots)" false -}}

{{- /* WSL detection: env var first (fast), then /proc fallback. */ -}}
{{- $isWSL := false -}}
{{- if env "WSL_DISTRO_NAME" -}}
{{-   $isWSL = true -}}
{{- else if stat "/proc/sys/fs/binfmt_misc/WSLInterop" -}}
{{-   $isWSL = true -}}
{{- end -}}

{{- /* Distro detection: chezmoi.osRelease.id on Linux, "darwin" on macOS. */ -}}
{{- $distro := "unknown" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   $distro = "darwin" -}}
{{- else if eq .chezmoi.os "linux" -}}
{{-   $distro = .chezmoi.osRelease.id -}}
{{- end -}}

[data]
    gitName         = {{ $gitName | quote }}
    gitEmail        = {{ $gitEmail | quote }}
    enableGcloudAdc = {{ $enableGcloudAdc }}
    isWSL           = {{ $isWSL }}
    distro          = {{ $distro | quote }}

[edit]
    command = "vim"

[diff]
    pager = "delta"
