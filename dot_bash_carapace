# Carapace shell completion — bridges + bash init.
# Sourced from ~/.bashrc.

# Allow carapace to provide completions for commands defined in other shells.
export CARAPACE_BRIDGES='zsh,fish,bash,inshellisense'

# Defines _carapace_completer and registers it for all supported commands.
if command -v carapace >/dev/null 2>&1; then
  source <(carapace _carapace)
fi
