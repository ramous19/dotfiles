#!/usr/bin/env bash
# Interactive git identity + SSH key setup.
# Idempotent — safe to re-run; only acts on missing state.
#
# Seeds answers from chezmoi data when available (`gitName`, `gitEmail`).

set -euo pipefail
log() { printf '\033[0;34m[git-ssh]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[git-ssh]\033[0m %s\n' "$*" >&2; }

# Skip in non-interactive contexts (CI, devcontainer build, Codespaces prebuild).
if [ ! -t 0 ] || [ ! -t 1 ]; then
  log "Non-interactive shell — skipping git+SSH setup."
  exit 0
fi

# ─── Git identity ───────────────────────────────────────────────────────────
SEED_NAME={{ .gitName  | quote }}
SEED_EMAIL={{ .gitEmail | quote }}

current_name="$(git config --global user.name  2>/dev/null || true)"
current_email="$(git config --global user.email 2>/dev/null || true)"

if [ -z "$current_name" ]; then
  if [ -n "$SEED_NAME" ]; then
    git config --global user.name "$SEED_NAME"
    log "Set git user.name = $SEED_NAME (from chezmoi data)."
  else
    read -rp "Git name: " input
    git config --global user.name "$input"
  fi
fi

if [ -z "$current_email" ]; then
  if [ -n "$SEED_EMAIL" ]; then
    git config --global user.email "$SEED_EMAIL"
    log "Set git user.email = $SEED_EMAIL (from chezmoi data)."
  else
    read -rp "Git email: " input
    git config --global user.email "$input"
  fi
fi

git config --global init.defaultBranch main
git config --global pull.ff only

# ─── SSH key for GitHub ─────────────────────────────────────────────────────
SSH_KEY="$HOME/.ssh/id_ed25519"
if [ ! -f "$SSH_KEY" ]; then
  read -rp "Generate a new SSH key for GitHub? [Y/n]: " gen
  if [[ ! "$gen" =~ ^[Nn]$ ]]; then
    email="$(git config --global user.email)"
    mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"
    ssh-keygen -t ed25519 -C "$email" -f "$SSH_KEY" -N ""
    log "Generated $SSH_KEY"
  fi
fi

if [ -f "$SSH_KEY" ]; then
  eval "$(ssh-agent -s)" >/dev/null 2>&1 || true
  ssh-add "$SSH_KEY" 2>/dev/null || true

  if command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1; then
    if gh ssh-key list 2>/dev/null | awk '{print $1}' | grep -qx "$(awk '{print $1" "$2}' "${SSH_KEY}.pub" | awk '{print $1}')"; then
      log "SSH key already registered with GitHub."
    else
      read -rp "Add SSH key to GitHub via gh CLI? [Y/n]: " add
      if [[ ! "$add" =~ ^[Nn]$ ]]; then
        gh ssh-key add "${SSH_KEY}.pub" --title "$(hostname)-$(date +%Y%m%d)" \
          && log "SSH key registered with GitHub." \
          || warn "gh ssh-key add failed."
      fi
    fi
  else
    log "Public key (add manually at https://github.com/settings/ssh/new):"
    cat "${SSH_KEY}.pub"
  fi

  git config --global url."git@github.com:".insteadOf "https://github.com/"
fi

# ─── ~/.ssh/config entry for github.com ─────────────────────────────────────
SSH_CONFIG="$HOME/.ssh/config"
if ! grep -q '^Host github.com' "$SSH_CONFIG" 2>/dev/null; then
  mkdir -p "$HOME/.ssh"
  cat >> "$SSH_CONFIG" <<'EOF'

Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519
  AddKeysToAgent yes
EOF
  chmod 600 "$SSH_CONFIG"
  log "Added github.com entry to ~/.ssh/config."
fi

log "Test with:  ssh -T git@github.com"
