#!/usr/bin/env bash
# Install system-level packages that must come from the OS package manager:
# build toolchain, fonts, system daemons (docker), shell-completion engine
# (carapace), the cloud SDK, and the core editors/multiplexers.
#
# Everything user-space (node, terraform, kubectl, helm, jq, fzf, zoxide,
# starship, gh, gum, delta, …) lives in ~/.config/mise/config.toml and is
# installed by the mise step — not here.
#
# This script is distro-aware. Add new distros by extending the if/elif chain.
#
# Re-run: bump the timestamp in any of the helper functions to force chezmoi
# to re-execute this run_once script.

set -euo pipefail

log() { printf '\033[0;34m[system-pkgs]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[system-pkgs]\033[0m %s\n' "$*" >&2; }

{{ if or (eq .distro "ubuntu") (eq .distro "debian") -}}
# ─── Ubuntu / Debian (apt) ────────────────────────────────────────────────────
log "Installing base packages via apt…"
sudo apt-get update -qq
sudo apt-get install -y -qq \
  ca-certificates curl wget git build-essential fontconfig gnupg lsb-release \
  vim tree tmux unzip software-properties-common

# Carapace (shell completion engine) — apt repo from release.dl.carapace.sh
if ! command -v carapace >/dev/null 2>&1; then
  log "Adding carapace apt repo…"
  sudo mkdir -p /etc/apt/keyrings
  curl -fsSL https://apt.carapace.sh/carapace.gpg | sudo tee /etc/apt/keyrings/carapace.gpg >/dev/null
  echo "deb [signed-by=/etc/apt/keyrings/carapace.gpg] https://apt.carapace.sh/ /" \
    | sudo tee /etc/apt/sources.list.d/carapace.list >/dev/null
  sudo apt-get update -qq
  sudo apt-get install -y -qq carapace-bin
fi

# Docker Engine
if ! command -v docker >/dev/null 2>&1; then
  log "Adding Docker apt repo…"
  sudo install -m 0755 -d /etc/apt/keyrings
  curl -fsSL https://download.docker.com/linux/ubuntu/gpg | sudo tee /etc/apt/keyrings/docker.asc >/dev/null
  sudo chmod a+r /etc/apt/keyrings/docker.asc
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo "$VERSION_CODENAME") stable" \
    | sudo tee /etc/apt/sources.list.d/docker.list >/dev/null
  sudo apt-get update -qq
  sudo apt-get install -y -qq docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
  if ! groups "$USER" | grep -q '\bdocker\b'; then
    sudo usermod -aG docker "$USER"
    warn "Added $USER to the 'docker' group. Log out and back in to use docker without sudo."
  fi
fi

# Google Cloud SDK
if ! command -v gcloud >/dev/null 2>&1; then
  log "Adding gcloud apt repo…"
  curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg \
    | sudo gpg --dearmor -o /usr/share/keyrings/cloud.google.gpg
  echo "deb [signed-by=/usr/share/keyrings/cloud.google.gpg] https://packages.cloud.google.com/apt cloud-sdk main" \
    | sudo tee /etc/apt/sources.list.d/google-cloud-sdk.list >/dev/null
  sudo apt-get update -qq
  sudo apt-get install -y -qq google-cloud-cli
fi

{{ else if eq .distro "arch" -}}
# ─── Arch Linux (pacman + AUR) ────────────────────────────────────────────────
log "Installing base packages via pacman…"
sudo pacman -Sy --noconfirm --needed \
  curl wget git base-devel fontconfig \
  vim tree tmux unzip docker

# Enable docker daemon
if systemctl list-unit-files 2>/dev/null | grep -q '^docker\.service'; then
  sudo systemctl enable --now docker || true
  if ! groups "$USER" | grep -q '\bdocker\b'; then
    sudo usermod -aG docker "$USER"
    warn "Added $USER to the 'docker' group. Log out and back in to use docker without sudo."
  fi
fi

# AUR helper (yay) — bootstrap if missing; needed for carapace-bin and google-cloud-cli.
if ! command -v yay >/dev/null 2>&1; then
  log "Bootstrapping yay (AUR helper)…"
  tmpdir="$(mktemp -d)"
  git clone --depth 1 https://aur.archlinux.org/yay-bin.git "$tmpdir/yay-bin"
  (cd "$tmpdir/yay-bin" && makepkg -si --noconfirm)
  rm -rf "$tmpdir"
fi

# AUR packages
yay -S --noconfirm --needed carapace-bin google-cloud-cli || \
  warn "AUR install failed — install carapace-bin and google-cloud-cli manually."

{{ else if eq .distro "darwin" -}}
# ─── macOS — most of these come via Homebrew (next step) ──────────────────────
log "macOS: system packages handled by Homebrew step; skipping."

{{ else -}}
warn "Unknown distro '{{ .distro }}' — skipping system package install."
warn "Add a branch in .chezmoiscripts/run_once_before_10-system-packages.sh.tmpl for it."
{{- end }}

log "Done."
